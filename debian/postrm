#!/bin/sh
set -e

case "$1" in
  purge)
    # Remove nginx config
    rm -f /etc/nginx/sites-enabled/otzi
    rm -f /etc/nginx/sites-available/otzi
    if command -v nginx >/dev/null 2>&1; then
      systemctl reload nginx 2>/dev/null || true
    fi

    # Remove environment file
    rm -f /etc/default/otzi

    # Remove data (user confirms via dpkg --purge)
    rm -rf /var/lib/otzi

    # Remove system user
    if id otzi >/dev/null 2>&1; then
      deluser --system otzi 2>/dev/null || true
    fi
    ;;
esac

#DEBHELPER#
